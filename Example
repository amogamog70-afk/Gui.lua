                TrackCorner.CornerRadius = UDim.new(0, 3)
                TrackCorner.Parent = Track
                
                local Gradient = Instance.new("UIGradient")
                Gradient.Parent = Track
                
                local Thumb = Instance.new("Frame")
                Thumb.Size = UDim2.new(0, 10, 0, 10)
                Thumb.AnchorPoint = Vector2.new(0.5, 0.5)
                Thumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                Thumb.Parent = Track
                
                local ThumbCorner = Instance.new("UICorner")
                ThumbCorner.CornerRadius = UDim.new(1, 0)
                ThumbCorner.Parent = Thumb
                
                local ThumbStroke = Instance.new("UIStroke")
                ThumbStroke.Color = Color3.fromRGB(0, 0, 0)
                ThumbStroke.Thickness = 1
                ThumbStroke.Parent = Thumb
                
                local ValLabel = Instance.new("TextLabel")
                ValLabel.Size = UDim2.new(0, 30, 1, 0)
                ValLabel.Position = UDim2.new(1, -30, 0, 0)
                ValLabel.BackgroundTransparency = 1
                ValLabel.TextColor3 = Library.Theme.Text
                ValLabel.Font = Enum.Font.GothamMedium
                ValLabel.TextSize = 9
                ValLabel.TextXAlignment = Enum.TextXAlignment.Right
                ValLabel.Parent = RowFrame
                
                local val = initVal
                local isDragging = false
                local scrollFrame = nil
                
                local function setScrolling(scrollState)
                    if not scrollFrame then scrollFrame = getParentScrollingFrame(PickerFrame) end
                    if scrollFrame then scrollFrame.ScrollingEnabled = scrollState end
                end
                
                local function updateDrag()
                    local mouseLocation = getMousePosition()
                    local percentage = math.clamp((mouseLocation.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                    val = minVal + ((maxVal - minVal) * percentage)
                    
                    local displayPercentage = (val - minVal) / (maxVal - minVal)
                    Thumb.Position = UDim2.new(displayPercentage, 0, 0.5, 0)
                    ValLabel.Text = tostring(math.round(val)) .. suffixText
                    
                    if rowName == "H" then currentHue = val / 360
                    elseif rowName == "S" then currentSat = val / 100
                    elseif rowName == "V" then currentVal = val / 100
                    elseif rowName == "A" then currentAlpha = val / 100
                    end
                    updateAllColors("slider")
                end
                
                local dragConnection = nil
                Track.InputBegan:Connect(function(input)
                    if isClickInput(input) then
                        isDragging = true
                        setScrolling(false)
                        if dragConnection then dragConnection:Disconnect() end
                        dragConnection = RunService.RenderStepped:Connect(updateDrag)
                        updateDrag()
                    end
                end)
                
                trackConnection(UserInputService.InputEnded:Connect(function(input)
                    if isClickInput(input) and isDragging then
                        isDragging = false
                        if dragConnection then dragConnection:Disconnect(); dragConnection = nil end
                        setScrolling(true)
                    end
                end))
                
                local function setValue(newVal)
                    val = newVal
                    local displayPercentage = (val - minVal) / (maxVal - minVal)
                    Thumb.Position = UDim2.new(displayPercentage, 0, 0.5, 0)
                    ValLabel.Text = tostring(math.round(val)) .. suffixText
                end
                
                sliders[rowName] = {setValue = setValue, Track = Track, Gradient = Gradient}
                setupGradientFunc(Gradient, Track)
            end
            
            createMiniSlider("H", 0, 360, currentHue * 360, "", function(grad)
                grad.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
                    ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255, 255, 0)),
                    ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0, 255, 0)),
                    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
                    ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0, 0, 255)),
                    ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 0, 255)),
                    ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0))
                })
            end)
            
            createMiniSlider("S", 0, 100, currentSat * 100, "%", function(grad)
                grad.Color = ColorSequence.new(Color3.fromRGB(255, 255, 255), Color3.fromHSV(currentHue, 1, 1))
            end)
            
            createMiniSlider("V", 0, 100, currentVal * 100, "%", function(grad)
                grad.Color = ColorSequence.new(Color3.fromRGB(0, 0, 0), Color3.fromHSV(currentHue, 1, 1))
            end)
            
            createMiniSlider("A", 0, 100, currentAlpha * 100, "%", function(grad, track)
                track.BackgroundColor3 = Color3.fromHSV(currentHue, currentSat, currentVal)
                grad.Transparency = NumberSequence.new({
                    NumberSequenceKeypoint.new(0, 1),
                    NumberSequenceKeypoint.new(1, 0)
                })
            end)
            
            local BottomRow = Instance.new("Frame")
            BottomRow.Size = UDim2.new(1, -12, 0, 20)
            BottomRow.BackgroundTransparency = 1
            BottomRow.Parent = PickerContainer
            
            local HexInputFrame = Instance.new("Frame")
