        holder.Size = UDim2.new(0, 13, 0, 26)
        holder.BackgroundTransparency = 1
        holder.LayoutOrder = layoutOrder
        holder.Parent = WmContent
        local ln = Instance.new("Frame")
        ln.Size = UDim2.new(0, 1, 0, 12)
        ln.Position = UDim2.new(0.5, 0, 0.5, -6)
        ln.BackgroundColor3 = Library.Theme.Stroke
        ln.BorderSizePixel = 0
        ln.Parent = holder
    end

    local wmPlayer = Players.LocalPlayer

    -- ◆ Бренд
    local WmBrandLabel = Instance.new("TextLabel")
    WmBrandLabel.Size = UDim2.new(0, 0, 0, 26)
    WmBrandLabel.AutomaticSize = Enum.AutomaticSize.X
    WmBrandLabel.BackgroundTransparency = 1
