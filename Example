local _connections = {}
local function trackConnection(conn)
    table.insert(_connections, conn)
    return conn
end

local _activeTweens = setmetatable({}, {__mode = "k"})
local function tween(object, info, properties)
    if _activeTweens[object] then
        _activeTweens[object]:Cancel()
    end
    local anim = TweenService:Create(object, TweenInfo.new(info), properties)
    _activeTweens[object] = anim
    anim:Play()
    anim.Completed:Connect(function()
        if _activeTweens[object] == anim then
            _activeTweens[object] = nil
        end
    end)
    return anim
end

local function isClickInput(input)
    return input.UserInputType == Enum.UserInputType.MouseButton1 
        or input.UserInputType == Enum.UserInputType.Touch
end

local function isMoveInput(input)
    return input.UserInputType == Enum.UserInputType.MouseMovement 
        or input.UserInputType == Enum.UserInputType.Touch
end

local function getMousePosition()
    return UserInputService:GetMouseLocation()
end

local function isMouseOverFrame(frame)
    if not frame or not frame.Parent then return false end
    local mousePos = getMousePosition()
    local pos = frame.AbsolutePosition
    local size = frame.AbsoluteSize
    return mousePos.X >= pos.X and mousePos.X <= pos.X + size.X
       and mousePos.Y >= pos.Y and mousePos.Y <= pos.Y + size.Y
end

local function isMouseOverPopup(popup)
    local frame = popup.frame
    if not frame or not frame.Parent then return false end
    local function checkRecursive(f)
        if f:IsA("GuiObject") then
            if isMouseOverFrame(f) then return true end
        end
        for _, child in ipairs(f:GetChildren()) do
            if checkRecursive(child) then return true end
        end
        return false
    end
    return checkRecursive(frame)
end

local function makeDraggable(frame, dragAnchor)
    local dragging, dragInput, dragStart, startPos
    trackConnection(dragAnchor.InputBegan:Connect(function(input)
        if isClickInput(input) then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end))
    trackConnection(dragAnchor.InputChanged:Connect(function(input)
        if isMoveInput(input) then
            dragInput = input
        end
    end))
    trackConnection(UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end))
end

local function getParentScrollingFrame(obj)
    local parent = obj.Parent
    while parent do
        if parent:IsA("ScrollingFrame") then
            return parent
        end
        parent = parent.Parent
    end
    return nil
end

