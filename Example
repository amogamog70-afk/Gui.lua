    local isSearching = false
    local function performSearch(searchText)
        if not SearchResultsPage then return end
        if searchText == "" then
            if isSearching then
                isSearching = false
                SearchResultsPage.Visible = false
                for _, win in ipairs(_allWindows) do
                    if win.frame and win.originalParent then
                        win.frame.Parent = win.originalParent
                        win.frame.Visible = true
                    end
                end
                if Main.CurrentTab and Main.Pages[Main.CurrentTab] then
                    Main.Pages[Main.CurrentTab].Page.Visible = true
                    updateLayout(Main.CurrentTab)
                end
                for _, item in ipairs(_searchableItems) do
                    if item.frame then
                        item.frame.Visible = true
                    end
                end
            end
            return
        end

        isSearching = true
        if Main.CurrentTab and Main.Pages[Main.CurrentTab] then
            Main.Pages[Main.CurrentTab].Page.Visible = false
        end
        SearchResultsPage.Visible = true

        local query, layoutQuery, visualQuery = cleanSearchText(searchText)

        local matchedItems = {}
        for _, item in ipairs(_searchableItems) do
            if item.frame then
                local itemLower = string.lower(item.label)
                local matched = string.find(itemLower, query, 1, true) 
                    or string.find(itemLower, layoutQuery, 1, true)
                    or string.find(itemLower, visualQuery, 1, true)
                item.frame.Visible = (matched ~= nil)
                matchedItems[item.frame] = (matched ~= nil)
            end
        end

        local visibleWindows = {}
        for _, win in ipairs(_allWindows) do
            local winNameLower = string.lower(win.name)
            local winMatched = string.find(winNameLower, query, 1, true)
                or string.find(winNameLower, layoutQuery, 1, true)
                or string.find(winNameLower, visualQuery, 1, true)

            local hasMatchedItems = false
            for _, item in ipairs(_searchableItems) do
                if item.frame and item.frame:IsDescendantOf(win.frame) then
                    if winMatched then
                        item.frame.Visible = true
                        hasMatchedItems = true
                    elseif matchedItems[item.frame] then
                        hasMatchedItems = true
                    end
                end
            end

            if hasMatchedItems then
                table.insert(visibleWindows, win)
                win.frame.Visible = true
            else
                win.frame.Visible = false
            end
        end

        for i, win in ipairs(visibleWindows) do
            win.frame.Parent = (i % 2 == 1) and SearchLeftColumn or SearchRightColumn
        end

        if updateSearchResultsLayout then
            updateSearchResultsLayout(#visibleWindows)
        end
    end

