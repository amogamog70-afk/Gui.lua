    KBAccentBar.Size = UDim2.new(1, 0, 0, 2)
    KBAccentBar.BackgroundColor3 = Library.Theme.Accent
    KBAccentBar.BorderSizePixel = 0
    KBAccentBar.Parent = KBFrame

    local KBAccentCorner = Instance.new("UICorner")
    KBAccentCorner.CornerRadius = UDim.new(0, 6)
    KBAccentCorner.Parent = KBAccentBar

    local KBContent = Instance.new("Frame")
    KBContent.Name = "Content"
    KBContent.Size = UDim2.new(1, 0, 1, -2)
    KBContent.Position = UDim2.new(0, 0, 0, 2)
    KBContent.BackgroundTransparency = 1
    KBContent.Parent = KBFrame

    local KBLabel = Instance.new("TextLabel")
    KBLabel.Size = UDim2.new(0.5, 0, 1, 0)
    KBLabel.Position = UDim2.new(0, 8, 0, 0)
    KBLabel.BackgroundTransparency = 1
    KBLabel.Text = "Menu Key:"
    KBLabel.TextColor3 = Library.Theme.TextDim
    KBLabel.Font = Enum.Font.GothamMedium
    KBLabel.TextSize = 9
    KBLabel.TextXAlignment = Enum.TextXAlignment.Left
    KBLabel.Parent = KBContent

    local KBButton = Instance.new("TextButton")
    KBButton.Size = UDim2.new(0.5, -12, 0, 16)
    KBButton.Position = UDim2.new(0.5, 4, 0.5, -8)
    KBButton.BackgroundColor3 = Color3.fromRGB(30, 30, 36)
    KBButton.Text = Library.ToggleKey.Name
    KBButton.TextColor3 = Library.Theme.Text
    KBButton.Font = Enum.Font.GothamBold
    KBButton.TextSize = 8
    KBButton.Parent = KBContent

    local KBCorner2 = Instance.new("UICorner")
    KBCorner2.CornerRadius = UDim.new(0, 4)
    KBCorner2.Parent = KBButton

    local KBStroke2 = Instance.new("UIStroke")
    KBStroke2.Color = Library.Theme.Stroke
    KBStroke2.Thickness = 1
    KBStroke2.Parent = KBButton

    local isKBChanging = false
    KBButton.MouseButton1Click:Connect(function()
        if isKBChanging then return end
        isKBChanging = true
        KBButton.Text = "..."
        KBStroke2.Color = Library.Theme.Accent
    end)

    trackConnection(UserInputService.InputBegan:Connect(function(input)
        if isKBChanging then
            if input.UserInputType == Enum.UserInputType.Keyboard then
                isKBChanging = false
                Library.ToggleKey = input.KeyCode
                KBButton.Text = Library.ToggleKey.Name
                KBStroke2.Color = Library.Theme.Stroke
                Main:Notify("Settings", "Menu key bind changed to: " .. Library.ToggleKey.Name, 3)
            end
        end
    end))

    makeDraggable(KBFrame, KBFrame)
    makeDraggable(WmFrame, WmFrame)

    return Main
end

return Library
