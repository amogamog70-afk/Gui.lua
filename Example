    Main:Notify("System", "Server link copied to clipboard.", 3)
end)

UtilsWindow:CreateSeparator()
UtilsWindow:CreateLabel("VoltEclipse Library v2.7")

local InterfaceWindow = MiscTab:CreateWindow("Interface")
InterfaceWindow:CreateDropdown("Menu Theme", {
    "Default Purple", "Ocean Blue", "Crimson Red", "Emerald Green", "Sunset Orange"
}, false, "Default Purple", function(selected)
    print("[Theme] Selected:", selected)
end)

InterfaceWindow:CreateToggle("Show Notifications", true, function(state)
    print("[UI] Notifications:", state)
end)

InterfaceWindow:CreateButton("Send Test Notification", function()
    Main:Notify("Test", "This is a test notification! 🔔", 4)
end)

InterfaceWindow:CreateSeparator()
InterfaceWindow:CreateButton("Unload Interface", function()
    Main:Destroy()
    print("[VoltEclipse] UI destroyed.")
end)
