        local BodyL = Instance.new("TextLabel")
        BodyL.Size = UDim2.new(1, -20, 0, 20)
        BodyL.Position = UDim2.new(0, 10, 0, 25)
        BodyL.BackgroundTransparency = 1
        BodyL.Text = text
        BodyL.TextColor3 = Library.Theme.Text
        BodyL.Font = Enum.Font.Gotham
        BodyL.TextSize = 12
        BodyL.TextXAlignment = Enum.TextXAlignment.Left
        BodyL.Parent = Notif

        tween(Notif, 0.2, {Size = UDim2.new(0, 260, 0, 50)})
        task.delay(duration, function()
            tween(Notif, 0.3, {Size = UDim2.new(0, 260, 0, 0)})
            task.delay(0.35, function() if Notif.Parent then Notif:Destroy() end end)
        end)
    end

    return Main
end

return Library
