            HexStroke.Thickness = 1
            HexStroke.Parent = HexInputFrame
            
            local HexBox = Instance.new("TextBox")
            HexBox.Size = UDim2.new(1, -6, 1, 0)
            HexBox.Position = UDim2.new(0, 3, 0, 0)
            HexBox.BackgroundTransparency = 1
            HexBox.TextColor3 = Library.Theme.Text
            HexBox.Font = Enum.Font.Gotham
            HexBox.TextSize = 9
            HexBox.TextXAlignment = Enum.TextXAlignment.Center
            HexBox.Parent = HexInputFrame

            local RgbLabel = Instance.new("TextLabel")
            RgbLabel.Size = UDim2.new(0, 100, 0, 18)
            RgbLabel.Position = UDim2.new(0, 90, 0, 0)
            RgbLabel.BackgroundTransparency = 1
            RgbLabel.Font = Enum.Font.GothamMedium
            RgbLabel.TextSize = 8
            RgbLabel.TextColor3 = Library.Theme.TextDim
            RgbLabel.TextXAlignment = Enum.TextXAlignment.Left
            RgbLabel.Parent = BottomRow

            local PickerPadding = Instance.new("UIPadding")
            PickerPadding.PaddingLeft = UDim.new(0, 6)
            PickerPadding.PaddingRight = UDim.new(0, 6)
            PickerPadding.PaddingTop = UDim.new(0, 6)
            PickerPadding.PaddingBottom = UDim.new(0, 6)
            PickerPadding.Parent = PickerContainer
            
            local PickerLayout = Instance.new("UIListLayout")
            PickerLayout.SortOrder = Enum.SortOrder.LayoutOrder
            PickerLayout.Padding = UDim.new(0, 4)
            PickerLayout.Parent = PickerContainer
            
            updateAllColors = function(source)
                local solidColor = Color3.fromHSV(currentHue, currentSat, currentVal)
                ColorBox.BackgroundColor3 = solidColor
                ColorBox.BackgroundTransparency = 1 - currentAlpha
                
                local r, g, b = math.round(solidColor.R * 255), math.round(solidColor.G * 255), math.round(solidColor.B * 255)
                RgbLabel.Text = string.format("RGB: %d, %d, %d", r, g, b)

                if source ~= "hex" then HexBox.Text = rgbToHex(solidColor) end
                if source == "hex" or source == "init" then
                    sliders["H"].setValue(currentHue * 360)
                    sliders["S"].setValue(currentSat * 100)
                    sliders["V"].setValue(currentVal * 100)
                    sliders["A"].setValue(currentAlpha * 100)
                end
                sliders["S"].Gradient.Color = ColorSequence.new(Color3.fromRGB(255, 255, 255), Color3.fromHSV(currentHue, 1, 1))
                sliders["V"].Gradient.Color = ColorSequence.new(Color3.fromRGB(0, 0, 0), Color3.fromHSV(currentHue, 1, 1))
                sliders["A"].Track.BackgroundColor3 = solidColor
                callback(solidColor, currentAlpha)
            end

            HexBox.FocusLost:Connect(function()
                local text = HexBox.Text
                local success, parsedColor = pcall(function() return hexToRgb(text) end)
                if success and parsedColor then
                    currentHue, currentSat, currentVal = parsedColor:ToHSV()
                    updateAllColors("hex")
                else
                    HexBox.Text = rgbToHex(ColorBox.BackgroundColor3)
                end
            end)

            local isPickerOpen = false
            local pickerPopupId = nil

            local function closePicker()
                if isPickerOpen then
                    isPickerOpen = false
                    PickerContainer.Visible = false
                    PickerContainer.Size = UDim2.new(1, 0, 0, 0)
                    PickerFrame.ZIndex = 1
                    clearPopup(pickerPopupId)
                end
            end

            local function openPickerPanel()
                isPickerOpen = true
                PickerContainer.Visible = true
                PickerContainer.Size = UDim2.new(1, 0, 0, 94)
                PickerFrame.ZIndex = 100
                pickerPopupId = openPopup(PickerFrame, closePicker)
            end

            ColorBox.MouseButton1Click:Connect(function()
                if isPickerOpen then closePicker() else openPickerPanel() end
            end)

            updateAllColors("init")
            table.insert(_searchableItems, {frame = PickerFrame, label = pickerText})
            return PickerFrame
        end

        return Elements
    end

