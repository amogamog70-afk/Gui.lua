    KBCorner.Parent = KBFrame

    local KBStroke = Instance.new("UIStroke")
    KBStroke.Color = Library.Theme.Accent
    KBStroke.Thickness = 1
    KBStroke.Transparency = 0.5
    KBStroke.Parent = KBFrame

    local KBAccentBar = Instance.new("Frame")
