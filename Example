            end

            function Window:Remove()
                PageData.WindowCount = math.max(0, PageData.WindowCount - 1)
                for i, win in ipairs(_allWindows) do
                    if win.frame == WindowFrame then
                        table.remove(_allWindows, i)
                        break
                    end
                end
                if WindowFrame and WindowFrame.Parent then WindowFrame:Destroy() end
                updateLayout(tabName)
            end
            return Window
