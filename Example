    WmAvatarContainer.BackgroundColor3 = Library.Theme.Section
    WmAvatarContainer.BorderSizePixel = 0
    WmAvatarContainer.LayoutOrder = 3
    WmAvatarContainer.Parent = WmContent

    local WmAvatarContCorner = Instance.new("UICorner")
