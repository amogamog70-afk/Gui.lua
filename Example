            ContainerStroke.Thickness = 1
            ContainerStroke.Parent = PickerContainer

            local currentHue, currentSat = defaultColor:ToHSV()
            local currentVal = 1
            local currentAlpha = 1
            
            local sliders = {}
            local updateAllColors -- Задекларируем
            
            local function createMiniSlider(rowName, minVal, maxVal, initVal, suffixText, setupGradientFunc)
                local RowFrame = Instance.new("Frame")
                RowFrame.Size = UDim2.new(1, -12, 0, 14)
                RowFrame.BackgroundTransparency = 1
                RowFrame.ZIndex = 100
                RowFrame.Parent = PickerContainer
                
                local RowLabel = Instance.new("TextLabel")
                RowLabel.Size = UDim2.new(0, 15, 1, 0)
                RowLabel.BackgroundTransparency = 1
                RowLabel.Text = rowName
                RowLabel.TextColor3 = Library.Theme.TextDim
                RowLabel.Font = Enum.Font.GothamBold
                RowLabel.TextSize = 9
                RowLabel.TextXAlignment = Enum.TextXAlignment.Left
                RowLabel.ZIndex = 100
                RowLabel.Parent = RowFrame
                
                local Track = Instance.new("ImageButton")
                Track.Size = UDim2.new(1, -55, 0, 6)
                Track.Position = UDim2.new(0, 20, 0.5, -3)
                Track.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                Track.AutoButtonColor = false
                Track.ZIndex = 100
                Track.Parent = RowFrame
                
                local TrackCorner = Instance.new("UICorner")
                TrackCorner.CornerRadius = UDim.new(0, 3)
                TrackCorner.Parent = Track
                
                local Gradient = Instance.new("UIGradient")
                Gradient.Parent = Track
                
                local Thumb = Instance.new("Frame")
                Thumb.Size = UDim2.new(0, 10, 0, 10)
                Thumb.AnchorPoint = Vector2.new(0.5, 0.5)
                Thumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                Thumb.ZIndex = 100
                Thumb.Parent = Track
                
                local ThumbCorner = Instance.new("UICorner")
                ThumbCorner.CornerRadius = UDim.new(1, 0)
                ThumbCorner.Parent = Thumb
                
                local ThumbStroke = Instance.new("UIStroke")
                ThumbStroke.Color = Color3.fromRGB(0, 0, 0)
                ThumbStroke.Thickness = 1
                ThumbStroke.Parent = Thumb
                
                local ValLabel = Instance.new("TextLabel")
                ValLabel.Size = UDim2.new(0, 30, 1, 0)
                ValLabel.Position = UDim2.new(1, -30, 0, 0)
                ValLabel.BackgroundTransparency = 1
                ValLabel.TextColor3 = Library.Theme.Text
                ValLabel.Font = Enum.Font.GothamMedium
                ValLabel.TextSize = 9
                ValLabel.TextXAlignment = Enum.TextXAlignment.Right
                ValLabel.ZIndex = 100
                ValLabel.Parent = RowFrame
                
                local val = initVal
                local isDragging = false
                local scrollFrame = nil
                
                local function setScrolling(scrollState)
                    if not scrollFrame then
                        scrollFrame = getParentScrollingFrame(PickerFrame)
                    end
                    if scrollFrame then
                        scrollFrame.ScrollingEnabled = scrollState
                    end
                end
                
                local function updateDrag()
                    local mouseLocation = getMousePosition()
                    local percentage = math.clamp((mouseLocation.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                    val = minVal + ((maxVal - minVal) * percentage)
                    
                    local displayPercentage = (val - minVal) / (maxVal - minVal)
                    Thumb.Position = UDim2.new(displayPercentage, 0, 0.5, 0)
                    ValLabel.Text = tostring(math.round(val)) .. suffixText
                    
                    if rowName == "H" then
                        currentHue = val / 360
                    elseif rowName == "S" then
                        currentSat = val / 100
                    end
                    updateAllColors("slider")
                end
                
                local dragConnection = nil
                Track.InputBegan:Connect(function(input)
                    if isClickInput(input) then
                        isDragging = true
                        setScrolling(false)
                        if dragConnection then
                            dragConnection:Disconnect()
                        end
                        dragConnection = RunService.RenderStepped:Connect(updateDrag)
                        updateDrag()
                    end
                end)
                
                trackConnection(UserInputService.InputEnded:Connect(function(input)
                    if isClickInput(input) and isDragging then
                        isDragging = false
                        if dragConnection then
                            dragConnection:Disconnect()
                            dragConnection = nil
                        end
                        setScrolling(true)
                    end
                end))
                
                local function setValue(newVal)
                    val = newVal
                    local displayPercentage = (val - minVal) / (maxVal - minVal)
                    Thumb.Position = UDim2.new(displayPercentage, 0, 0.5, 0)
                    ValLabel.Text = tostring(math.round(val)) .. suffixText
                end
                
                sliders[rowName] = {setValue = setValue, Track = Track, Gradient = Gradient}
                setupGradientFunc(Gradient, Track)
            end
            
            -- Инициализируем 2 слайдера
            -- 1. HUE (0-360)
            createMiniSlider("H", 0, 360, currentHue * 360, "", function(grad)
                grad.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
                    ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255, 255, 0)),
                    ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0, 255, 0)),
                    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
                    ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0, 0, 255)),
                    ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 0, 255)),
                    ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0))
                })
            end)
            
            -- 2. SATURATION (0-100)
            createMiniSlider("S", 0, 100, currentSat * 100, "%", function(grad)
                grad.Color = ColorSequence.new(Color3.fromRGB(255, 255, 255), Color3.fromHSV(currentHue, 1, 1))
            end)
            
            -- Hex и RGB строка внизу
            local BottomRow = Instance.new("Frame")
            BottomRow.Size = UDim2.new(1, -12, 0, 20)
            BottomRow.BackgroundTransparency = 1
            BottomRow.ZIndex = 100
            BottomRow.Parent = PickerContainer
            
            local HexInputFrame = Instance.new("Frame")
            HexInputFrame.Size = UDim2.new(0, 64, 0, 18)
            HexInputFrame.Position = UDim2.new(0, 20, 0, 0)
            HexInputFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 36)
            HexInputFrame.ZIndex = 100
            HexInputFrame.Parent = BottomRow
            
            local HexCorner = Instance.new("UICorner")
            HexCorner.CornerRadius = UDim.new(0, 3)
            HexCorner.Parent = HexInputFrame
            
            local HexStroke = Instance.new("UIStroke")
            HexStroke.Color = Library.Theme.Stroke
            HexStroke.Thickness = 1
            HexStroke.Parent = HexInputFrame
            
            local HexBox = Instance.new("TextBox")
            HexBox.Size = UDim2.new(1, -6, 1, 0)
            HexBox.Position = UDim2.new(0, 3, 0, 0)
            HexBox.BackgroundTransparency = 1
            HexBox.TextColor3 = Library.Theme.Text
            HexBox.Font = Enum.Font.Gotham
            HexBox.TextSize = 9
            HexBox.TextXAlignment = Enum.TextXAlignment.Center
            HexBox.ZIndex = 100
            HexBox.Parent = HexInputFrame

            local RgbLabel = Instance.new("TextLabel")
            RgbLabel.Size = UDim2.new(0, 100, 0, 18)
            RgbLabel.Position = UDim2.new(0, 90, 0, 0)
            RgbLabel.BackgroundTransparency = 1
            RgbLabel.Font = Enum.Font.GothamMedium
            RgbLabel.TextSize = 8
            RgbLabel.TextColor3 = Library.Theme.TextDim
            RgbLabel.TextXAlignment = Enum.TextXAlignment.Left
            RgbLabel.ZIndex = 100
            RgbLabel.Parent = BottomRow

            -- Разметка контейнера слайдеров
            local PickerPadding = Instance.new("UIPadding")
            PickerPadding.PaddingLeft = UDim.new(0, 6)
            PickerPadding.PaddingRight = UDim.new(0, 6)
            PickerPadding.PaddingTop = UDim.new(0, 6)
            PickerPadding.PaddingBottom = UDim.new(0, 6)
            PickerPadding.Parent = PickerContainer
            
            local PickerLayout = Instance.new("UIListLayout")
            PickerLayout.SortOrder = Enum.SortOrder.LayoutOrder
            PickerLayout.Padding = UDim.new(0, 4)
            PickerLayout.Parent = PickerContainer

            updateAllColors = function(source)
                local solidColor = Color3.fromHSV(currentHue, currentSat, currentVal)
                ColorBox.BackgroundColor3 = solidColor
                ColorBox.BackgroundTransparency = 1 - currentAlpha
                
                local r, g, b = math.round(solidColor.R * 255), math.round(solidColor.G * 255), math.round(solidColor.B * 255)
                RgbLabel.Text = string.format("RGB: %d, %d, %d", r, g, b)

                if source ~= "hex" then
                    HexBox.Text = rgbToHex(solidColor)
                end

                if source == "hex" or source == "init" then
                    sliders["H"].setValue(currentHue * 360)
                    sliders["S"].setValue(currentSat * 100)
                end

                -- Динамическое обновление градиентов других слайдеров
                sliders["S"].Gradient.Color = ColorSequence.new(Color3.fromRGB(255, 255, 255), Color3.fromHSV(currentHue, 1, 1))

                callback(solidColor, currentAlpha)
            end

            HexBox.FocusLost:Connect(function()
                local text = HexBox.Text
                local success, parsedColor = pcall(function() return hexToRgb(text) end)
                if success and parsedColor then
                    currentHue, currentSat, _ = parsedColor:ToHSV()
                    currentVal = 1
                    updateAllColors("hex")
                else
                    HexBox.Text = rgbToHex(ColorBox.BackgroundColor3)
                end
            end)

            local isPickerOpen = false
            local Backdrop = nil

            local function closePicker()
                if isPickerOpen then
                    isPickerOpen = false
                    PickerContainer.Visible = false
                    PickerContainer.Size = UDim2.new(1, 0, 0, 0)
                    PickerFrame.ZIndex = 1
                    clearPopup(pickerPopupId)
                end
            end

            local function openPickerPanel()
                isPickerOpen = true
                PickerContainer.Visible = true
                PickerContainer.Size = UDim2.new(1, 0, 0, 58)
                PickerFrame.ZIndex = 100
                pickerPopupId = openPopup(PickerFrame, closePicker)
            end

            ColorBox.MouseButton1Click:Connect(function()
                if isPickerOpen then
                    closePicker()
                else
                    openPickerPanel()
                end
            end)

            updateAllColors("init")

            if tooltipText then
                addTooltip(PickerFrame, tooltipText)
            end

            table.insert(_searchableItems, {frame = PickerFrame, label = pickerText})
            
            return PickerFrame
        end

