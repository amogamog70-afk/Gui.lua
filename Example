        duration = duration or 3
        local Notif = Instance.new("Frame")
        Notif.Size = UDim2.new(0, 260, 0, 0)
        Notif.Position = UDim2.new(1, -270, 1, -10)
        Notif.BackgroundColor3 = Library.Theme.Sidebar
