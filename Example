    WmAvatarImage.Parent = WmAvatarContainer

    local WmAvatarImgCorner = Instance.new("UICorner")
    WmAvatarImgCorner.CornerRadius = UDim.new(1, 0)
    WmAvatarImgCorner.Parent = WmAvatarImage

    task.spawn(function()
        pcall(function()
            local thumbContent = Players:GetUserThumbnailAsync(wmPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)
            WmAvatarImage.Image = thumbContent
        end)
    end)

    -- Имя пользователя
    local WmUsernameLabel = Instance.new("TextLabel")
    WmUsernameLabel.Size = UDim2.new(0, 0, 0, 26)
    WmUsernameLabel.AutomaticSize = Enum.AutomaticSize.X
    WmUsernameLabel.BackgroundTransparency = 1
    WmUsernameLabel.Text = " " .. wmPlayer.DisplayName
    WmUsernameLabel.TextColor3 = Library.Theme.Text
    WmUsernameLabel.Font = Enum.Font.GothamMedium
    WmUsernameLabel.TextSize = 10
    WmUsernameLabel.LayoutOrder = 4
    WmUsernameLabel.Parent = WmContent

    wmCreateSep(5)

    -- FPS
    local WmFpsLabel = Instance.new("TextLabel")
    WmFpsLabel.Size = UDim2.new(0, 0, 0, 26)
    WmFpsLabel.AutomaticSize = Enum.AutomaticSize.X
    WmFpsLabel.BackgroundTransparency = 1
    WmFpsLabel.Text = "0 FPS"
    WmFpsLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    WmFpsLabel.Font = Enum.Font.GothamMedium
    WmFpsLabel.TextSize = 10
    WmFpsLabel.LayoutOrder = 6
    WmFpsLabel.Parent = WmContent

    wmCreateSep(7)

    -- Пинг
    local WmPingText = Instance.new("TextLabel")
    WmPingText.Size = UDim2.new(0, 0, 0, 26)
    WmPingText.AutomaticSize = Enum.AutomaticSize.X
    WmPingText.BackgroundTransparency = 1
    WmPingText.Text = "0ms"
    WmPingText.TextColor3 = Color3.fromRGB(100, 255, 100)
    WmPingText.Font = Enum.Font.GothamMedium
    WmPingText.TextSize = 10
    WmPingText.LayoutOrder = 8
    WmPingText.Parent = WmContent

    wmCreateSep(9)

    -- Время
    local WmTimeText = Instance.new("TextLabel")
    WmTimeText.Size = UDim2.new(0, 0, 0, 26)
    WmTimeText.AutomaticSize = Enum.AutomaticSize.X
    WmTimeText.BackgroundTransparency = 1
    WmTimeText.Text = "00:00"
    WmTimeText.TextColor3 = Library.Theme.TextDim
    WmTimeText.Font = Enum.Font.GothamMedium
    WmTimeText.TextSize = 10
    WmTimeText.LayoutOrder = 10
    WmTimeText.Parent = WmContent

    -- Обновление FPS, Ping, Time в реальном времени
    local _wmFpsData = {}
    local _wmTick = 0

    trackConnection(RunService.RenderStepped:Connect(function(deltaTime)
        _wmTick = _wmTick + 1
        table.insert(_wmFpsData, 1 / deltaTime)
        if #_wmFpsData > 60 then table.remove(_wmFpsData, 1) end

        if _wmTick % 30 == 0 then
            -- FPS (среднее за последние 60 кадров)
            local total = 0
            for _, f in ipairs(_wmFpsData) do total = total + f end
            local fps = math.floor(total / math.max(1, #_wmFpsData))
            WmFpsLabel.Text = fps .. " FPS"
            if fps >= 50 then
                WmFpsLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
            elseif fps >= 30 then
                WmFpsLabel.TextColor3 = Color3.fromRGB(255, 255, 100)
            else
                WmFpsLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            end

            -- Ping
            pcall(function()
                local ms = math.floor(wmPlayer:GetNetworkPing() * 1000)
                WmPingText.Text = ms .. "ms"
                if ms <= 80 then
                    WmPingText.TextColor3 = Color3.fromRGB(100, 255, 100)
                elseif ms <= 150 then
                    WmPingText.TextColor3 = Color3.fromRGB(255, 255, 100)
                else
                    WmPingText.TextColor3 = Color3.fromRGB(255, 100, 100)
                end
            end)

            -- Время
            pcall(function()
                WmTimeText.Text = os.date("%H:%M")
            end)
        end
    end))

    -- Menu Keybind Widget
    local KBFrame = Instance.new("Frame")
    KBFrame.Name = "MenuKeybindWidget"
    KBFrame.Size = UDim2.new(0, 130, 0, 28)
    KBFrame.Position = UDim2.new(0, 10, 0, 38)
