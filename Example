        MessageLabel.Size = UDim2.new(1, -12, 1, -32)
        MessageLabel.Position = UDim2.new(0, 6, 0, 28)
        MessageLabel.BackgroundTransparency = 1
        MessageLabel.Text = message
        MessageLabel.TextColor3 = Library.Theme.TextDim
        MessageLabel.Font = Enum.Font.Gotham
        MessageLabel.TextSize = 9
        MessageLabel.TextWrapped = true
        MessageLabel.TextXAlignment = Enum.TextXAlignment.Left
        MessageLabel.TextYAlignment = Enum.TextYAlignment.Top
        MessageLabel.Parent = NotifFrame

        task.wait(duration)
        tween(NotifFrame, 0.3, {BackgroundTransparency = 1})
        tween(NotifStroke, 0.3, {Transparency = 1})
        tween(TitleLabel, 0.3, {TextTransparency = 1})
        tween(MessageLabel, 0.3, {TextTransparency = 1})
        task.wait(0.3)
        NotifFrame:Destroy()
    end

