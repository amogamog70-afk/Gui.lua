        local NotifStroke = Instance.new("UIStroke")
        NotifStroke.Color = Library.Theme.Accent
        NotifStroke.Thickness = 1.5
        NotifStroke.Parent = NotifFrame

        local TitleLabel = Instance.new("TextLabel")
        TitleLabel.Name = "Title"
