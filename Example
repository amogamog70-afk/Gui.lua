            local function closeModeMenu()
                if isModeOpen then
                    isModeOpen = false
                    ModeScroll.Visible = false
                    KeybindFrame.ZIndex = 1
                    if kbBackdrop then
                        kbBackdrop:Destroy()
                        kbBackdrop = nil
                    end
                end
            end

            local function openModeMenu()
                isModeOpen = true
                ModeScroll.Visible = true
                KeybindFrame.ZIndex = 100
                
                kbBackdrop = Instance.new("TextButton")
                kbBackdrop.Name = "KeybindModeBackdrop"
                kbBackdrop.Size = UDim2.new(1, 0, 1, 0)
                kbBackdrop.BackgroundTransparency = 1
                kbBackdrop.Text = ""
                kbBackdrop.ZIndex = 99
                kbBackdrop.Parent = ScreenGui
                
                kbBackdrop.MouseButton1Click:Connect(closeModeMenu)
            end

            ModeBtn.MouseButton1Click:Connect(function()
                if isModeOpen then
                    closeModeMenu()
                else
                    openModeMenu()
                end
            end)

            local modeOptions = {}
            local function updateModeText()
                ModeBtn.Text = currentMode
                if currentMode == "Always" then
                    ModeBtn.TextColor3 = Library.Theme.Accent
                else
                    ModeBtn.TextColor3 = Library.Theme.TextDim
                end
                for name, opt in pairs(modeOptions) do
                    opt.TextColor3 = name == currentMode and Library.Theme.Accent or Library.Theme.TextDim
                end
            end

            local function createModeOption(mName, layoutOrder)
                local Opt = Instance.new("TextButton")
                Opt.Size = UDim2.new(1, 0, 0, 17)
                Opt.BackgroundTransparency = 1
                Opt.Text = mName
                Opt.TextColor3 = mName == currentMode and Library.Theme.Accent or Library.Theme.TextDim
                Opt.Font = Enum.Font.GothamMedium
                Opt.TextSize = 8
                Opt.LayoutOrder = layoutOrder
                Opt.ZIndex = 100
                Opt.Parent = ModeScroll

                Opt.MouseEnter:Connect(function()
                    tween(Opt, 0.1, {BackgroundTransparency = 0, BackgroundColor3 = Color3.fromRGB(30, 30, 36)})
                    Opt.TextColor3 = Library.Theme.Text
                end)
                Opt.MouseLeave:Connect(function()
                    tween(Opt, 0.1, {BackgroundTransparency = 1})
                    Opt.TextColor3 = currentMode == mName and Library.Theme.Accent or Library.Theme.TextDim
                end)

                Opt.MouseButton1Click:Connect(function()
                    currentMode = mName
                    updateModeText()
                    closeModeMenu()
                    
                    if currentMode == "Always" then
                        trigger(true)
                    else
                        trigger(false)
                    end
                end)
                
                modeOptions[mName] = Opt
            end

            createModeOption("Always", 1)
            createModeOption("Hold", 2)
            createModeOption("Toggle", 3)
            
            updateModeText()

            KeyBtn.MouseButton1Click:Connect(function()
                if isBinding then return end
                isBinding = true
                KeyBtn.Text = "[...]"
                KeyStroke.Color = Library.Theme.Accent
            end)

            trackConnection(UserInputService.InputBegan:Connect(function(input, gp)
                if gp and not isBinding then return end
                if isBinding then
                    local boundInput = nil
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        if input.KeyCode == Enum.KeyCode.Escape then
                            boundInput = Enum.KeyCode.Unknown
                        else
                            boundInput = input.KeyCode
                        end
                    elseif input.UserInputType == Enum.UserInputType.MouseButton1 
                        or input.UserInputType == Enum.UserInputType.MouseButton2 
                        or input.UserInputType == Enum.UserInputType.MouseButton3 
                        or input.UserInputType == Enum.UserInputType.MouseButton4 
                        or input.UserInputType == Enum.UserInputType.MouseButton5 then
                        boundInput = input.UserInputType
                    end
                    
                    if boundInput then
                        isBinding = false
                        currentKey = boundInput
                        KeyBtn.Text = getBindName(currentKey)
                        KeyStroke.Color = Library.Theme.Stroke
                        
                        if currentMode == "Always" then
                            trigger(true)
                        else
                            trigger(false)
                        end
                    end
                else
                    local isPressed = false
                    if typeof(currentKey) == "EnumItem" then
                        if currentKey.EnumType == Enum.KeyCode then
                            isPressed = (input.KeyCode == currentKey)
                        else
                            isPressed = (input.UserInputType == currentKey)
                        end
                    end
                    
                    local isUnknown = (typeof(currentKey) == "EnumItem" and currentKey.EnumType == Enum.KeyCode and currentKey == Enum.KeyCode.Unknown)
                    if isPressed and not isUnknown then
                        if currentMode == "Toggle" then
                            trigger(not state)
                        elseif currentMode == "Hold" then
                            trigger(true)
                        end
                    end
                end
            end))

            trackConnection(UserInputService.InputEnded:Connect(function(input, gp)
                if not isBinding and currentMode == "Hold" then
                    local isReleased = false
                    if typeof(currentKey) == "EnumItem" then
                        if currentKey.EnumType == Enum.KeyCode then
                            isReleased = (input.KeyCode == currentKey)
                        else
                            isReleased = (input.UserInputType == currentKey)
                        end
                    end
                    local isUnknown = (typeof(currentKey) == "EnumItem" and currentKey.EnumType == Enum.KeyCode and currentKey == Enum.KeyCode.Unknown)
                    if isReleased and not isUnknown then
                        trigger(false)
                    end
                end
            end))

            if currentMode == "Always" then
                task.spawn(function()
                    trigger(true)
                end)
            end

            if tooltipText then
                addTooltip(KeybindFrame, tooltipText)
            end

            table.insert(_searchableItems, {frame = KeybindFrame, label = keybindText})

            return KeybindFrame
        end

        return Elements
    end

